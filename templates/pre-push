#!/usr/bin/env bash
# ==============================
# Local-Deploy - Git pre-push Hook
# Auto-generated by local-deploy init
# ==============================

# This hook is invoked by 'git push' and triggers the local-deploy build & deploy pipeline.
# Build/deploy runs in the background and logs to file - push is never blocked.

echo ""
echo "============================================"
echo "  Local-Deploy: pre-push hook triggered"
echo "============================================"
echo ""

# Determine the project root (where .git/ lives)
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$PROJECT_ROOT" ]; then
    echo "[WARN] Could not determine project root. Skipping local-deploy."
    exit 0
fi

# Log file: same directory as local-deploy.yml (project root), overwrite each run
LOG_FILE="$PROJECT_ROOT/local-deploy.log"

# Local-Deploy installation path (auto-filled by local-deploy init)
LOCAL_DEPLOY_HOME="__LOCAL_DEPLOY_HOME__"

# Check if local-deploy is available and run in background with log redirection
if command -v local-deploy &>/dev/null; then
    echo "[INFO] Starting deploy in background. Log: $LOG_FILE"
    cd "$PROJECT_ROOT" && nohup local-deploy deploy --hook > "$LOG_FILE" 2>&1 &
elif [ -f "$PROJECT_ROOT/local-deploy.sh" ]; then
    echo "[INFO] Starting deploy in background. Log: $LOG_FILE"
    cd "$PROJECT_ROOT" && nohup bash "$PROJECT_ROOT/local-deploy.sh" deploy --hook > "$LOG_FILE" 2>&1 &
elif [ -f "$LOCAL_DEPLOY_HOME/local-deploy.sh" ]; then
    echo "[INFO] Starting deploy in background. Log: $LOG_FILE"
    cd "$PROJECT_ROOT" && nohup bash "$LOCAL_DEPLOY_HOME/local-deploy.sh" deploy --hook > "$LOG_FILE" 2>&1 &
else
    echo "[WARN] local-deploy not found. Skipping build & deploy."
    echo "[WARN] Install with: install.sh or place local-deploy.sh in project root."
fi

# Always exit 0 - never block git push
exit 0
